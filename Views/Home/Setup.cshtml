@{
    ViewData["Title"] = "Hosting Setup";
}

<h1>Hosting Setup</h1>

<article class="stat-card">
    <p>
        Montana Meshtastic Community strives to be transparent and open source to the best of its ability.
        Here is what is used to run our backend to support all this.
    </p>

    <ul>
        <li>
            Fedora 42 VPS at
            <a href="https://www.racknerd.com/" target="_blank" rel="noopener noreferrer">RackNerd</a>
            <ul>
                <li>
                    Tailscale - private mesh VPN used for secure remote administration and service access.
                </li>
                <li>
                    Podman
                    <ul>
                        <li>Portainer - GUI management interface for container operations.</li>
                        <li>ASP.Net - This Website</li>
                        <li>MQTT - Mosquitto</li>
                        <li>
                            <a href="https://potatomesh.montanamesh.com" target="_blank" rel="noopener noreferrer">PotatoMesh Web</a>
                        </li>
                    </ul>
                </li>
            </ul>
        </li>
        <li>
            Wormhole ingress node - Arch Linux Dell OptiPlex
            <ul>
                <li>
                    Tailscale - private link back to the MontanaMesh VPS for PotatoMesh ingestion.
                </li>
                <li>
                    Podman
                    <ul>
                        <li>PotatoMesh Ingress - reads the attached Meshtastic radio and forwards node, position, telemetry, and message data to PotatoMesh Web.</li>
                    </ul>
                </li>
            </ul>
        </li>
    </ul>
</article>
